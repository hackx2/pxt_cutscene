<xml xmlns="https://developers.google.com/blockly/xml"><variables></variables><block type="pxt-on-start" id="oI:w|{AYPT7-60Lcz6JZ" x="20" y="20"><statement name="HANDLER"><block type="typescript_statement" id="L4;Cx*.%`k{p0oU70}R|"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace cutscene {" line1="    /**" line2="     * Event method type" line3="     */" line4="    export type EventMethod = (I: CutsceneHandler) =&gt; void;" line5="" line6="    /**" line7="     * Event schema object" line8="     */" line9="    export type Event = {" line10="        /**" line11="         * Event identification reference" line12="         */" line13="        id: string, // Used for differentiating events from each other" line14="" line15="        /**" line16="         * When the event should run in **miliseconds**" line17="         */" line18="        time: number, // When the event should play" line19="" line20="        /**" line21="         * The event method to run." line22="         */" line23="        method: EventMethod // method" line24="    }" line25="" line26="    export interface IHandler {" line27="        add(t: number, id: string, method: EventMethod): void" line28="        remove(id: string): void" line29="        start(): void" line30="        stop(): void" line31="    }" line32="" line33="    /**" line34="     * Enable verbosity (e.g. more descriptive commenting)" line35="     */" line36="    export let verboseMode: boolean = false;" line37="" line38="    // rest doesn't seem to work correctly on this version of typescript :&lt;" line39="    function verbose(...msg: any[]): void {" line40="        if (!verboseMode) return;" line41="        console.log(`{CS:VERBOSE}: ${msg}`);" line42="    }" line43="" line44="    //% block" line45="    export class CutsceneHandler implements IHandler {" line46="        // time since- y'know, right???" line47="        _time: number = 0;" line48="" line49="        public stopWhenFinished: boolean = false;" line50="" line51="        // An array of all locally registered events" line52="        _events: Event[] = [];" line53="        _startTime: number = 0;" line54="        _eventPtr: number = 0;" line55="        _isSorted: boolean = true;" line56="" line57="        // whether to continue updating, or not..." line58="        _continue: boolean = false;" line59="        private get continue(): boolean {" line60="            return this._continue;" line61="        }" line62="        private set continue(v: boolean) {" line63="            verbose(`Playback ${v ? &quot;enabled&quot; : &quot;disabled&quot;}`)" line64="            this._continue = v;" line65="        }" line66="" line67="        constructor() {" line68="            game.onUpdate(() =&gt; this._update());" line69="        }" line70="" line71="        _update(): void {" line72="            if (!this.continue) return;" line73="" line74="            const currentTime: number = game.runtime() - this._startTime;" line75="" line76="            while (this._eventPtr &lt; this._events.length &amp;&amp; this._events[this._eventPtr].time &lt;= currentTime) {" line77="                const evnt: Event = this._events[this._eventPtr];" line78="                verbose(`Running &quot;${evnt.id}&quot; at ${evnt.time}ms`);" line79="                evnt.method(this); this._eventPtr++;" line80="            }" line81="" line82="            if (this.stopWhenFinished &amp;&amp; this._eventPtr &gt;= this._events.length) {" line83="                this.stop();" line84="            }" line85="        }" line86="" line87="        /** " line88="         * Add an event to the handler's list." line89="         */" line90="        //% block=&quot;add event $handler to $this with id $id at $t ms&quot;" line91="        //% t.shadow=timePicker" line92="        //% draggableParameters=&quot;reporter&quot;" line93="        //% weight=99" line94="        //% blockGap=8" line95="        //% blockId=&quot;cutscene_add_event&quot;" line96="        public add(t: number, id: string, handler: EventMethod): void {" line97="            this._events.push({ id: id, time: t, method: handler });" line98="            this._isSorted = false;" line99="            verbose(`Regsitered event to id &quot;${id}&quot; @ ${t / 1000} second(s)`);" line100="" line101="        }" line102="" line103="        /**" line104="         * Remove an event." line105="         */" line106="        //% block=&quot;remove event from $this using $id&quot;" line107="        public remove(id: string): void {" line108="            this._events = this._events.filter(e =&gt; e.id !== id)" line109="        }" line110="" line111="        /**" line112="         * Start the cutscene handler." line113="         */" line114="        //% block=&quot;start $this&quot;" line115="        public start(): void {" line116="            if (this._events.length === 0) return;" line117="" line118="            // Only sort if we've added new events" line119="            if (!this._isSorted) {" line120="                this._events.sort((a, b) =&gt; a.time - b.time);" line121="                this._isSorted = true;" line122="            }" line123="" line124="            this._eventPtr = 0;" line125="            this._startTime = game.runtime();" line126="            this.continue = true;" line127="        }" line128="" line129="        /**" line130="         * Stop the cutscene handler." line131="         */" line132="        //% block=&quot;stop $this&quot;" line133="        public stop(): void {" line134="            this.continue = false;" line135="            // returning `this` messes blocks up :&lt;" line136="            // return this;" line137="        }" line138="    }" line139="" line140="    /**" line141="     * Use for registering events in block mode." line142="     * I guess this could be used as some kind of signal-like handler, but eh..." line143="     * " line144="     * To use events on block mode you'll need to require them using the `get global event` " line145="     * (also known as `Registry.get(&quot;EVENT_NAME&quot;)`) block." line146="     */" line147="    export class Registry {" line148="        /**" line149="         * Event map" line150="         */" line151="        static events: { [key: string]: EventMethod } = {};" line152="" line153="        /**" line154="         * Sets an event by it's `ID`." line155="         * @param id the id reference to the event" line156="         * @param the event callback" line157="         */" line158="        static set(id: string, callback: (handler: CutsceneHandler) =&gt; void): void {" line159="            Registry.events[id] = callback;" line160="        }" line161="" line162="        /**" line163="         * Retrieves an event by its `ID`." line164="         * @param id the name of the event to get" line165="         */" line166="        //% block=&quot;get global event $id&quot;" line167="        static get(id: string): EventMethod {" line168="            return Registry.events[id];" line169="        }" line170="    }" line171="" line172="    /**" line173="     * Register a static event" line174="     * " line175="     * This isn't automatically added to every `CutsceneHandler` instance..." line176="     * So instead you'll need to manually require them by calling `cutscene.Registry.get(&quot;EVENT_NAME&quot;)`," line177="     * which uses the type : `(handler:CutsceneHandler) =&gt; void`..." line178="     * " line179="     * @param id The name of this event (e.g., &quot;intro&quot;)" line180="     * @param callback the event callback" line181="     */" line182="    //% block=&quot;set global cutscene event $id&quot;" line183="    //% draggableParameters=&quot;reporter&quot;" line184="    export function registerStaticEvent(id: string, callback: (handler: CutsceneHandler) =&gt; void): void {" line185="        Registry.set(id, callback);" line186="    }" line187="" line188="    /**" line189="     * Create a cutscene handler" line190="     */" line191="    //% block=&quot;create cutscene&quot;" line192="    export function create(): CutsceneHandler {" line193="        return new CutsceneHandler();" line194="    }" line195="}" numlines="196"></mutation></block></statement></block></xml>